@startuml Login

actor Usuario

boundary "Tela de Login" as Tela
control "AuthController" as Controller
control "AuthService" as Service

Usuario -> Tela : Informa usuario
Tela -> Controller : login(usuario, senha)
Controller -> Service : autenticar(usuario, senha)
Service -> Controller : sucesso
Controller -> Tela : loginSucesso()
Tela -> Usuario : exibirTelaPrincipal()

@enduml